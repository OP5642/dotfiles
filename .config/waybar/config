{
    "layer": "top",
    "position": "top",
    "height": 36,
    "spacing": 4,
    "margin-top": 6,
    "margin-left": 10,
    "margin-right": 10,

    "modules-left": [
        "hyprland/workspaces",
        "hyprland/window"
    ],

    "modules-center": ["clock"],
    "modules-right": [
        "cpu",
        "temperature",
        "memory",
        "pulseaudio",
        "network#wifi",
        "battery"
    ],

    "hyprland/workspaces": {
        "format": "{icon}",
